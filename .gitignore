# Uploads - Mantener estructura de carpetas, ignorar archivos subidos
# Ignorar todos los archivos en carpetas de uploads
uploads/technical_visits/**/*
uploads/work_orders/reports/work_orders_reports_photos/**/*
uploads/work_orders/reports/work_orders_reports_documents/**/*

# Pero mantener los .gitkeep para preservar la estructura de carpetas
!uploads/technical_visits/.gitkeep
!uploads/work_orders/.gitkeep
!uploads/work_orders/reports/.gitkeep
!uploads/work_orders/reports/work_orders_reports_photos/.gitkeep
!uploads/work_orders/reports/work_orders_reports_documents/.gitkeep

