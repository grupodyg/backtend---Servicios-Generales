PORT=4012
JWT_SECRET=your_jwt_secret_here

# Timezone para consistencia de fechas (America/Lima = UTC-5)
# IMPORTANTE: Esta variable es OBLIGATORIA para que las fechas funcionen correctamente
# tanto en desarrollo local como en produccion (Railway)
TZ=America/Lima

# Prisma DB connection string
# Local:
DATABASE_URL="postgresql://postgres:password@localhost:5432/db_servicios_generales"
# Railway (ejemplo):
# DATABASE_URL="postgresql://user:pass@host:port/database"

# Wasabi S3 Storage
WASABI_ACCESS_KEY=your_wasabi_access_key
WASABI_SECRET_KEY=your_wasabi_secret_key
WASABI_BUCKET_UPLOADS=dig-ssgg-uploads
WASABI_BUCKET_BACKUPS=dig-ssgg-backups
WASABI_REGION=us-east-1
WASABI_ENDPOINT=https://s3.us-east-1.wasabisys.com
